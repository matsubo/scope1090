[Unit]
Description=scope1090 — Flask API server
After=scope1090-collector.service scope1090-restore.service
Wants=scope1090-restore.service

[Service]
Type=simple
Restart=always
RestartSec=5
ExecStart=/usr/share/scope1090/venv/bin/python3 -m scope1090.api
WorkingDirectory=/usr/share
Environment=SCOPE1090_DB=/run/scope1090/live.db

[Install]
WantedBy=multi-user.target
